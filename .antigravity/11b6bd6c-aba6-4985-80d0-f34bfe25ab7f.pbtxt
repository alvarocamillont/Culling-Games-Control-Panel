      target_content: "  <body class=\"bg-zinc-950 font-sans text-zinc-300 h-screen overflow-hidden flex flex-col scanlines selection:bg-purple-900 selection:text-purple-100\">\n\n    <!-- TOP HEADER -->\n    <header class=\"bg-zinc-900 border-b border-zinc-800 px-6 py-3.5 flex flex-col md:flex-row items-center justify-between gap-4 z-20 shrink-0\">\n      <!-- App Identity -->\n      <div class=\"flex items-center gap-3\">\n        <!-- Flashing Warning Dot -->\n        <span class=\"w-3 h-3 rounded-full bg-red-600 warning-pulse flex shrink-0\"></span>\n        <div>\n          <div class=\"flex items-center gap-2\">\n            <h1 class=\"font-display font-bold text-zinc-100 text-lg tracking-wider uppercase\">Culling Games</h1>\n            <span class=\"px-1.5 py-0.5 bg-red-950/50 border border-red-900/60 text-red-500 font-mono text-[10px] tracking-widest font-bold rounded\">\346\255\273\346\273\205\345\233\236\346\270\270</span>\n          </div>\n          <p class=\"text-zinc-500 font-mono text-xs uppercase tracking-widest\">Central Monitoring Panel \342\200\242 Kogane System 2.4.0</p>\n        </div>\n      </div>\n\n      <!-- Tactical Metadata -->\n      <div class=\"hidden lg:flex items-center gap-6 font-mono text-xs border-l border-zinc-800 pl-6\">\n        <div>\n          <span class=\"text-zinc-500 block uppercase text-[10px]\">Barrier Status</span>\n          <span class=\"text-emerald-400 font-semibold uppercase tracking-wider flex items-center gap-1.5\">\n            <span class=\"w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block animate-pulse\"></span> Stable / Active\n          </span>\n        </div>\n        <div>\n          <span class=\"text-zinc-500 block uppercase text-[10px]\">Active Colonies</span>\n          <span class=\"text-purple-400 font-semibold\">10 / 10 DECL</span>\n        </div>\n        <div>\n          <span class=\"text-zinc-500 block uppercase text-[10px]\">Game Rules</span>\n          <span class=\"text-zinc-300\">19 Sub-clauses</span>\n        </div>\n      </div>\n\n      <!-- Live Dynamic Clock -->\n      <div class=\"flex items-center gap-4 bg-zinc-950 border border-zinc-800 px-4 py-1.5 rounded-md font-mono text-xs\">\n        <div class=\"text-right\">\n          <span class=\"text-zinc-500 text-[10px] block uppercase\">Live System Time</span>\n          <span id=\"system-clock\" class=\"text-zinc-200 font-bold tracking-wider\">2026-06-30 18:25:23 UTC</span>\n        </div>\n        <div class=\"h-6 w-px bg-zinc-800\"></div>\n        <div class=\"flex flex-col items-center\">\n          <span class=\"text-zinc-500 text-[9px] block uppercase\">Feed</span>\n          <span class=\"text-emerald-500 font-bold uppercase tracking-widest text-[10px] animate-pulse\">\342\227\217 LIVE</span>\n        </div>\n      </div>\n    </header>"
      replacement_content: "  <body class=\"bg-zinc-950 text-zinc-300 font-sans h-screen overflow-hidden flex flex-col border-4 border-zinc-900 select-none scanlines selection:bg-purple-900 selection:text-purple-100\">\n\n    <!-- TOP NAVIGATION / SYSTEM STATUS -->\n    <header class=\"h-14 border-b border-zinc-800 bg-zinc-950 flex items-center justify-between px-6 shrink-0 z-20\">\n      <div class=\"flex items-center gap-4\">\n        <div class=\"w-3 h-3 rounded-full bg-red-600 warning-pulse flex shrink-0\"></div>\n        <div class=\"flex items-center gap-3\">\n          <h1 class=\"font-mono text-xs uppercase tracking-[0.3em] text-zinc-100 font-bold\">Culling Game // Central Control Panel</h1>\n          <span class=\"px-1.5 py-0.5 bg-red-950/40 border border-red-900/60 text-red-500 font-mono text-[9px] tracking-widest font-bold rounded\">\346\255\273\346\273\205\345\233\236\346\270\270</span>\n        </div>\n      </div>\n      <div class=\"flex gap-8 font-mono text-[10px] text-zinc-500 uppercase tracking-widest\">\n        <div class=\"flex flex-col items-end\">\n          <span class=\"text-zinc-400\">System Clock</span>\n          <span id=\"system-clock\" class=\"text-emerald-400 font-bold\">2026-06-30 18:25:23 UTC</span>\n        </div>\n        <div class=\"hidden md:flex flex-col items-end border-l border-zinc-800 pl-8 font-mono text-[10px]\">\n          <span class=\"text-zinc-400\">Encryption</span>\n          <span class=\"text-purple-400\">Grade 1 Static</span>\n        </div>\n      </div>\n    </header>"
    }
