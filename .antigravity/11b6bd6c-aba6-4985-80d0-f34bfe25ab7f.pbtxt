 Sub-clauses</span>\n        </div>\n      </div>\n\n      <!-- Live Dynamic Clock -->\n      <div class=\"flex items-center gap-4 bg-zinc-950 border border-zinc-800 px-4 py-1.5 rounded-md font-mono text-xs\">\n        <div class=\"text-right\">\n          <span class=\"text-zinc-500 text-[10px] block uppercase\">Live System Time</span>\n          <span id=\"system-clock\" class=\"text-zinc-200 font-bold tracking-wider\">2026-06-30 18:25:23 UTC</span>\n        </div>\n        <div class=\"h-6 w-px bg-zinc-800\"></div>\n        <div class=\"flex flex-col items-center\">\n          <span class=\"text-zinc-500 text-[9px] block uppercase\">Feed</span>\n          <span class=\"text-emerald-500 font-bold uppercase tracking-widest text-[10px] animate-pulse\">\342\227\217 LIVE</span>\n        </div>\n      </div>\n    </header>"
