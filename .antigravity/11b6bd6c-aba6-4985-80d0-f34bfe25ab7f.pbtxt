      replacement_content: "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>Culling Games Control Panel \342\200\242 \346\255\273\346\273\205\345\233\236\346\270\270</title>\n    <!-- Google Fonts for Tactical Display -->\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@500;700&display=swap\" rel=\"stylesheet\">\n    <!-- Tailwind CSS CDN -->\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <script>\n      tailwind.config = {\n        theme: {\n          extend: {\n            fontFamily: {\n              sans: [\'Inter\', \'sans-serif\'],\n              mono: [\'JetBrains Mono\', \'monospace\'],\n              display: [\'Space Grotesk\', \'sans-serif\'],\n            },\n            colors: {\n              zinc: {\n                950: \'#09090b\',\n                900: \'#121214\',\n                850: \'#1a1a1e\',\n                800: \'#222226\',\n                750: \'#2d2d33\',\n                700: \'#3a3a42\',\n                600: \'#52525b\',\n                500: \'#71717a\',\n                400: \'#a1a1aa\',\n                300: \'#d4d4d8\',\n                200: \'#e4e4e7\',\n                100: \'#f4f4f5\',\n              }\n            }\n          }\n        }\n      }\n    </script>\n    <style type=\"text/css\">\n      /* Custom scanlines and animations */\n      .scanlines {\n        position: relative;\n      }\n      .scanlines::before {\n        content: \" \";\n        display: block;\n        position: absolute;\n        top: 0; left: 0; bottom: 0; right: 0;\n        background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));\n        background-size: 100% 4px, 6px 100%;\n        z-index: 10;\n        pointer-events: none;\n        opacity: 0.15;\n      }\n      .scrollbar-thin::-webkit-scrollbar {\n        width: 6px;\n        height: 6px;\n      }\n      .scrollbar-thin::-webkit-scrollbar-track {\n        background: #09090b;\n      }\n      .scrollbar-thin::-webkit-scrollbar-thumb {\n        background: #222226;\n        border-radius: 3px;\n      }\n      .scrollbar-thin::-webkit-scrollbar-thumb:hover {\n        background: #3a3a42;\n      }\n      @keyframes pulse-glow {\n        0%, 100% {\n          opacity: 0.4;\n          box-shadow: 0 0 4px rgba(239, 68, 68, 0.4);\n        }\n        50% {\n          opacity: 1;\n          box-shadow: 0 0 12px rgba(239, 68, 68, 0.8);\n        }\n      }\n      .warning-pulse {\n        animation: pulse-glow 2s infinite ease-in-out;\n      }\n      @keyframes green-pulse {\n        0%, 100% {\n          transform: scale(1);\n          box-shadow: 0 0 4px rgba(16, 185, 129, 0.4);\n        }\n        50% {\n          transform: scale(1.1);\n          box-shadow: 0 0 10px rgba(16, 185, 129, 0.8);\n        }\n      }\n      .active-pulse {\n        animation: green-pulse 1.8s infinite ease-in-out;\n      }\n    </style>\n  </head>\n  <body class=\"bg-zinc-950 font-sans text-zinc-300 h-screen overflow-hidden flex flex-col scanlines selection:bg-purple-900 selection:text-purple-100\">\n\n    <!-- TOP HEADER -->\n    <header class=\"bg-zinc-900 border-b border-zinc-800 px-6 py-3.5 flex flex-col md:flex-row items-center justify-between gap-4 z-20 shrink-0\">\n      <!-- App Identity -->\n      <div class=\"flex items-center gap-3\">\n        <!-- Flashing Warning Dot -->\n        <span class=\"w-3 h-3 rounded-full bg-red-600 warning-pulse flex shrink-0\"></span>\n        <div>\n          <div class=\"flex items-center gap-2\">\n            <h1 class=\"font-display font-bold text-zinc-100 text-lg tracking-wider uppercase\">Culling Games</h1>\n            <span class=\"px-1.5 py-0.5 bg-red-950/50 border border-red-900/60 text-red-500 font-mono text-[10px] tracking-widest font-bold rounded\">\346\255\273\346\273\205\345\233\236\346\270\270</span>\n          </div>\n          <p class=\"text-zinc-500 font-mono text-xs uppercase tracking-widest\">Central Monitoring Panel \342\200\242 Kogane System 2.4.0</p>\n        </div>\n      </div>\n\n      <!-- Tactical Metadata -->\n      <div class=\"hidden lg:flex items-center gap-6 font-mono text-xs border-l border-zinc-800 pl-6\">\n        <div>\n          <span class=\"text-zinc-500 block uppercase text-[10px]\">Barrier Status</span>\n          <span class=\"text-emerald-400 font-semibold uppercase tracking-wider flex items-center gap-1.5\">\n            <span class=\"w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block animate-pulse\"></span> Stable / Active\n          </span>\n        </div>\n        <div>\n          <span class=\"text-zinc-500 block uppercase text-[10px]\">Active Colonies</span>\n          <span class=\"text-purple-400 font-semibold\">10 / 10 DECL</span>\n        </div>\n        <div>\n          <span class=\"text-zinc-500 block uppercase text-[10px]\">Game Rules</span>\n          <span class=\"text-zinc-300\">19 Sub-clauses</span>\n        </div>\n      </div>\n\n      <!-- Live Dynamic Clock -->\n      <div class=\"flex items-center gap-4 bg-zinc-950 border border-zinc-800 px-4 py-1.5 rounded-md font-mono text-xs\">\n        <div class=\"text-right\">\n          <span class=\"text-zinc-500 text-[10px] block uppercase\">Live System Time</span>\n          <span id=\"system-clock\" class=\"text-zinc-200 font-bold tracking-wider\">2026-06-30 18:25:23 UTC</span>\n        </div>\n        <div class=\"h-6 w-px bg-zinc-800\"></div>\n        <div class=\"flex flex-col items-center\">\n          <span class=\"text-zinc-500 text-[9px] block uppercase\">Feed</span>\n          <span class=\"text-emerald-500 font-bold uppercase tracking-widest text-[10px] animate-pulse\">\342\227\217 LIVE</span>\n        </div>\n      </div>\n    </header>\n\n    <!-- MAIN BODY SECTION -->\n    <main class=\"flex-1 flex flex-col md:flex-row overflow-hidden relative\">\n\n      <!-- LEFT PANEL: REGISTRATION ZONE & LOGS (30% width) -->\n      <section class=\"w-full md:w-[32%] lg:w-[28%] bg-zinc-900 border-r border-zinc-800 flex flex-col h-full overflow-hidden shrink-0\">\n        \n        <!-- Tab Selectors for Left Side -->\n        <div class=\"flex border-b border-zinc-800 font-mono text-xs uppercase shrink-0\">\n          <button id=\"tab-register-btn\" onclick=\"switchLeftTab(\'register\')\" class=\"flex-1 py-3 text-center border-b-2 border-purple-500 text-purple-400 font-bold bg-zinc-900/50 transition\">\n            Participation\n          </button>\n          <button id=\"tab-transfer-btn\" onclick=\"switchLeftTab(\'transfer\')\" class=\"flex-1 py-3 text-center border-b-2 border-transparent text-zinc-500 hover:text-zinc-300 transition\">\n            Point Transfer\n          </button>\n        </div>\n\n        <!-- Scrollable content area -->\n        <div class=\"flex-1 overflow-y-auto p-5 scrollbar-thin space-y-6\">\n\n          <!-- TAB 1: REGISTRATION FORM -->\n          <div id=\"left-tab-register\" class=\"space-y-5\">\n            <div>\n              <h2 class=\"font-display font-bold text-zinc-200 text-sm tracking-widest uppercase mb-1\">Sorcerer Registration</h2>\n              <p class=\"text-zinc-500 font-mono text-[11px] uppercase\">Submit credentials to authorize a new game participant.</p>\n            </div>\n\n            <form id=\"registration-form\" onsubmit=\"registerPlayer(event)\" class=\"space-y-4\">\n              <!-- Name field -->\n              <div class=\"space-y-1.5\">\n                <label for=\"reg-name\" class=\"block font-mono text-[11px] uppercase tracking-wider text-zinc-400 font-semibold\">Sorcerer Name <span class=\"text-red-500\">*</span></label>\n                <input \n                  type=\"text\" \n                  id=\"reg-name\" \n                  required \n                  placeholder=\"e.g., Hajime Kashimo\" \n                  class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3.5 py-2 text-sm text-zinc-100 placeholder-zinc-600 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition\"\n                >\n              </div>\n\n              <!-- Colony dropdown -->\n              <div class=\"space-y-1.5\">\n                <label for=\"reg-colony\" class=\"block font-mono text-[11px] uppercase tracking-wider text-zinc-400 font-semibold\">Starting Colony <span class=\"text-red-500\">*</span></label>\n                <select \n                  id=\"reg-colony\" \n                  required \n                  class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3.5 py-2 text-sm text-zinc-200 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition\"\n                >\n                  <option value=\"Tokyo Colony No. 1\">Tokyo Colony No. 1</option>\n                  <option value=\"Tokyo Colony No. 2\">Tokyo Colony No. 2</option>\n                  <option value=\"Sendai Colony\">Sendai Colony</option>\n                  <option value=\"Sakurajima Colony\">Sakurajima Colony</option>\n                  <option value=\"Kyoto Colony\">Kyoto Colony</option>\n                  <option value=\"Iwate Colony\">Iwate Colony</option>\n                </select>\n              </div>\n\n              <!-- Cursed Technique text area -->\n              <div class=\"space-y-1.5\">\n                <label for=\"reg-technique\" class=\"block font-mono text-[11px] uppercase tracking-wider text-zinc-400 font-semibold\">Cursed Technique <span class=\"text-zinc-500\">(Optional)</span></label>\n                <textarea \n                  id=\"reg-technique\" \n                  rows=\"2\"\n                  placeholder=\"Describe intrinsic technique, domain expansion, or cursed tools...\" \n                  class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3.5 py-2 text-sm text-zinc-100 placeholder-zinc-600 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition resize-none scrollbar-thin\"\n                ></textarea>\n              </div>\n\n              <!-- Points field -->\n              <div class=\"grid grid-cols-2 gap-4\">\n                <div class=\"space-y-1.5\">\n                  <label for=\"reg-points\" class=\"block font-mono text-[11px] uppercase tracking-wider text-zinc-400 font-semibold\">Starting Points</label>\n                  <input \n                    type=\"number\" \n                    id=\"reg-points\" \n                    value=\"0\" \n                    min=\"0\" \n                    max=\"1000\" \n                    class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3.5 py-2 text-sm text-zinc-100 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition\"\n                  >\n                </div>\n                <div class=\"space-y-1.5\">\n                  <label for=\"reg-status\" class=\"block font-mono text-[11px] uppercase tracking-wider text-zinc-400 font-semibold\">Initial Status</label>\n                  <select \n                    id=\"reg-status\" \n                    class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3.5 py-2 text-sm text-zinc-200 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition\"\n                  >\n                    <option value=\"Alive\" selected>Alive (Green)</option>\n                    <option value=\"Deceased\">Deceased (Red)</option>\n                  </select>\n                </div>\n              </div>\n\n              <!-- Submit button -->\n              <button \n                type=\"submit\" \n                class=\"w-full mt-2 bg-gradient-to-r from-red-700 to-purple-800 hover:from-red-600 hover:to-purple-700 text-zinc-100 font-display font-bold py-3 px-4 rounded text-xs tracking-widest uppercase transition-all duration-300 hover:shadow-[0_0_15px_rgba(239,68,68,0.3)] border border-red-500/20\"\n              >\n                Enter the Culling Game\n              </button>\n            </form>\n          </div>\n\n          <!-- TAB 2: POINT TRANSFER SIMULATOR -->\n          <div id=\"left-tab-transfer\" class=\"hidden space-y-5\">\n            <div>\n              <h2 class=\"font-display font-bold text-zinc-200 text-sm tracking-widest uppercase mb-1\">Point Transfer Mechanism</h2>\n              <p class=\"text-zinc-500 font-mono text-[11px] uppercase\">Enforce point-exchange rule #10 between active players.</p>\n            </div>\n\n            <form id=\"transfer-form\" onsubmit=\"simulateTransfer(event)\" class=\"space-y-4\">\n              <!-- Sender Selection -->\n              <div class=\"space-y-1.5\">\n                <label for=\"trans-sender\" class=\"block font-mono text-[11px] uppercase tracking-wider text-zinc-400 font-semibold\">Sender <span class=\"text-zinc-500\">(Transfers Out)</span></label>\n                <select \n                  id=\"trans-sender\" \n                  required \n                  class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3.5 py-2 text-sm text-zinc-200 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition\"\n                >\n                  <!-- Populated dynamically -->\n                </select>\n              </div>\n\n              <!-- Receiver Selection -->\n              <div class=\"space-y-1.5\">\n                <label for=\"trans-receiver\" class=\"block font-mono text-[11px] uppercase tracking-wider text-zinc-400 font-semibold\">Receiver <span class=\"text-zinc-500\">(Receives In)</span></label>\n                <select \n                  id=\"trans-receiver\" \n                  required \n                  class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3.5 py-2 text-sm text-zinc-200 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition\"\n                >\n                  <!-- Populated dynamically -->\n                </select>\n              </div>\n\n              <!-- Points to Transfer -->\n              <div class=\"space-y-1.5\">\n                <label for=\"trans-amount\" class=\"block font-mono text-[11px] uppercase tracking-wider text-zinc-400 font-semibold\">Points to Transfer</label>\n                <div class=\"relative\">\n                  <input \n                    type=\"number\" \n                    id=\"trans-amount\" \n                    value=\"1\" \n                    min=\"1\" \n                    class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3.5 py-2 pr-12 text-sm text-zinc-100 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition\"\n                  >\n                  <span class=\"absolute right-3.5 top-2 text-xs font-mono text-zinc-600 font-bold uppercase\">PTS</span>\n                </div>\n              </div>\n\n              <!-- Submit button -->\n              <button \n                type=\"submit\" \n                class=\"w-full mt-2 bg-purple-700 hover:bg-purple-600 text-zinc-100 font-display font-bold py-3 px-4 rounded text-xs tracking-widest uppercase transition-all duration-300 hover:shadow-[0_0_15px_rgba(139,92,246,0.3)] border border-purple-500/20\"\n              >\n                Authorize Point Transfer\n              </button>\n            </form>\n          </div>\n\n        </div>\n\n        <!-- MONOSPACE KOGANE LOGS FEED (FIXED AT THE BOTTOM) -->\n        <div class=\"bg-zinc-950 border-t border-zinc-800 p-4 h-48 flex flex-col shrink-0\">\n          <div class=\"flex items-center justify-between mb-2 shrink-0\">\n            <span class=\"font-mono text-[10px] tracking-wider text-zinc-400 font-bold uppercase flex items-center gap-1.5\">\n              <span class=\"w-1.5 h-1.5 bg-yellow-500 rounded-full animate-pulse\"></span> Kogane Broadcast Feed\n            </span>\n            <button onclick=\"clearLogs()\" class=\"font-mono text-[9px] text-zinc-600 hover:text-zinc-400 uppercase tracking-widest\">Clear</button>\n          </div>\n          <!-- Log List -->\n          <div id=\"logs-container\" class=\"flex-1 overflow-y-auto scrollbar-thin text-[11px] font-mono space-y-1.5 pr-2\">\n            <!-- Log items appended here -->\n          </div>\n        </div>\n\n      </section>\n\n      <!-- RIGHT PANEL: MONITORING GRID & STATS (70% width) -->\n      <section class=\"flex-1 bg-zinc-950 flex flex-col h-full overflow-hidden\">\n        \n        <!-- TOP GAME STATISTICS BAR -->\n        <div class=\"bg-zinc-900/60 border-b border-zinc-800 p-4 shrink-0\">\n          <div class=\"grid grid-cols-2 lg:grid-cols-4 gap-4 max-w-7xl mx-auto\">\n            \n            <!-- Metric 1: Registered -->\n            <div class=\"bg-zinc-900 border border-zinc-800 p-3.5 rounded-md flex items-center gap-4\">\n              <div class=\"p-2.5 bg-purple-950/40 border border-purple-900/40 text-purple-400 rounded\">\n                <!-- User Plus Icon SVG -->\n                <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z\" /></svg>\n              </div>\n              <div>\n                <span class=\"text-zinc-500 font-mono text-[10px] uppercase block tracking-wider\">Total Sorcerers</span>\n                <span id=\"stat-total-players\" class=\"font-display font-bold text-xl text-zinc-100\">0</span>\n              </div>\n            </div>\n\n            <!-- Metric 2: Points -->\n            <div class=\"bg-zinc-900 border border-zinc-800 p-3.5 rounded-md flex items-center gap-4\">\n              <div class=\"p-2.5 bg-yellow-950/40 border border-yellow-900/40 text-yellow-500 rounded\">\n                <!-- Coins/Star Icon SVG -->\n                <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z\" /></svg>\n              </div>\n              <div>\n                <span class=\"text-zinc-500 font-mono text-[10px] uppercase block tracking-wider\">Total Game Points</span>\n                <span id=\"stat-total-points\" class=\"font-display font-bold text-xl text-yellow-500\">0</span>\n              </div>\n            </div>\n\n            <!-- Metric 3: Mortalities -->\n            <div class=\"bg-zinc-900 border border-zinc-800 p-3.5 rounded-md flex items-center gap-4\">\n              <div class=\"p-2.5 bg-red-950/40 border border-red-900/40 text-red-500 rounded\">\n                <!-- Skull Icon SVG -->\n                <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\" /></svg>\n              </div>\n              <div>\n                <span class=\"text-zinc-500 font-mono text-[10px] uppercase block tracking-wider\">Deceased Rate</span>\n                <span id=\"stat-mortality-rate\" class=\"font-display font-bold text-xl text-red-400\">0%</span>\n              </div>\n            </div>\n\n            <!-- Metric 4: Rules Added -->\n            <div class=\"bg-zinc-900 border border-zinc-800 p-3.5 rounded-md flex items-center gap-4\">\n              <div class=\"p-2.5 bg-blue-950/40 border border-blue-900/40 text-blue-400 rounded\">\n                <!-- Scroll Icon SVG -->\n                <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z\" /></svg>\n              </div>\n              <div class=\"flex-1 flex justify-between items-center\">\n                <div>\n                  <span class=\"text-zinc-500 font-mono text-[10px] uppercase block tracking-wider\">Culling Rules</span>\n                  <span class=\"font-display font-bold text-xl text-zinc-100\">19 clauses</span>\n                </div>\n                <button onclick=\"openRulesModal()\" class=\"text-[10px] bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-mono uppercase px-2 py-1 rounded border border-zinc-700 transition\">View</button>\n              </div>\n            </div>\n\n          </div>\n        </div>\n\n        <!-- FILTERS & GRID CONTROLS -->\n        <div class=\"px-6 py-4 bg-zinc-950 border-b border-zinc-900 flex flex-col lg:flex-row items-center justify-between gap-4 shrink-0\">\n          \n          <!-- Search Field -->\n          <div class=\"relative w-full lg:w-96\">\n            <span class=\"absolute inset-y-0 left-0 flex items-center pl-3.5 pointer-events-none text-zinc-500\">\n              <!-- Search Icon SVG -->\n              <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\" /></svg>\n            </span>\n            <input \n              type=\"text\" \n              id=\"search-input\" \n              oninput=\"handleFilterChange()\" \n              placeholder=\"Search Sorcerers, Techniques...\" \n              class=\"w-full bg-zinc-900 border border-zinc-800 rounded pl-10 pr-4 py-2 text-sm text-zinc-200 placeholder-zinc-500 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition\"\n            >\n          </div>\n\n          <!-- Colony & Status Select Toggles -->\n          <div class=\"flex flex-wrap items-center gap-3 w-full lg:w-auto justify-end\">\n            <!-- Colony Filter Dropdown -->\n            <select \n              id=\"filter-colony\" \n              onchange=\"handleFilterChange()\" \n              class=\"bg-zinc-900 border border-zinc-800 rounded px-3.5 py-2 text-xs text-zinc-300 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition uppercase tracking-wider font-mono\"\n            >\n              <option value=\"ALL\">All Colonies</option>\n              <option value=\"Tokyo Colony No. 1\">Tokyo No. 1</option>\n              <option value=\"Tokyo Colony No. 2\">Tokyo No. 2</option>\n              <option value=\"Sendai Colony\">Sendai</option>\n              <option value=\"Sakurajima Colony\">Sakurajima</option>\n              <option value=\"Kyoto Colony\">Kyoto</option>\n              <option value=\"Iwate Colony\">Iwate</option>\n            </select>\n\n            <!-- Status Toggles -->\n            <div class=\"flex bg-zinc-900 p-0.5 rounded border border-zinc-800 text-[11px] font-mono uppercase tracking-wider\">\n              <button onclick=\"setStatusFilter(\'ALL\')\" id=\"filter-status-all\" class=\"px-3.5 py-1.5 rounded text-purple-400 bg-zinc-850 font-bold transition\">All</button>\n              <button onclick=\"setStatusFilter(\'Alive\')\" id=\"filter-status-alive\" class=\"px-3.5 py-1.5 rounded text-zinc-400 hover:text-zinc-200 transition\">Alive</button>\n              <button onclick=\"setStatusFilter(\'Deceased\')\" id=\"filter-status-deceased\" class=\"px-3.5 py-1.5 rounded text-zinc-400 hover:text-zinc-200 transition\">Deceased</button>\n            </div>\n\n            <!-- Reset Database -->\n            <button \n              onclick=\"resetSystem()\" \n              class=\"p-2 bg-zinc-900 hover:bg-zinc-800 text-zinc-500 hover:text-red-400 rounded border border-zinc-800 hover:border-red-900/50 transition-all cursor-pointer\"\n              title=\"Reset System to Default Sorcerers\"\n            >\n              <!-- Refresh Icon SVG -->\n              <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 8H17\" /></svg>\n            </button>\n          </div>\n        </div>\n\n        <!-- SCROLLABLE GRID CONTAINER -->\n        <div class=\"flex-1 overflow-y-auto p-6 scrollbar-thin\">\n          <div class=\"max-w-7xl mx-auto\">\n            <!-- Grid Layout -->\n            <div id=\"players-grid\" class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n              <!-- Cards dynamically inserted here -->\n            </div>\n\n            <!-- Empty State -->\n            <div id=\"empty-state\" class=\"hidden flex-col items-center justify-center py-20 text-center\">\n              <div class=\"w-14 h-14 rounded-full bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-600 mb-4 animate-bounce\">\n                <svg class=\"w-7 h-7\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\" /></svg>\n              </div>\n              <h3 class=\"font-display font-bold text-zinc-300 tracking-wider text-base uppercase\">No Sorcerers Detected</h3>\n              <p class=\"text-zinc-500 font-mono text-xs mt-1 max-w-sm\">No sorcerers match your search criteria. Register a new sorcerer or reset the panel database to default settings.</p>\n              <button onclick=\"resetSystem()\" class=\"mt-4 px-4 py-2 bg-purple-950/40 hover:bg-purple-900/40 border border-purple-900 text-purple-400 font-mono text-xs uppercase tracking-widest rounded transition\">Reset Database</button>\n            </div>\n          </div>\n        </div>\n\n        <!-- FOOTER TACTICAL MARGIN -->\n        <footer class=\"bg-zinc-900 border-t border-zinc-800 px-6 py-2.5 flex items-center justify-between text-[10px] font-mono text-zinc-500 shrink-0 select-none\">\n          <span>ALVARO.CAMILLONETO@GMAIL.COM \342\200\242 LICENSED INGRESS</span>\n          <span class=\"flex items-center gap-1.5\"><span class=\"w-1.5 h-1.5 bg-purple-500 rounded-full animate-ping\"></span> KOGANE INTEL SYNC SUCCESS</span>\n          <span>SECURE PROTOCOL JJK-C-01</span>\n        </footer>\n\n      </section>\n\n    </main>\n\n    <!-- RULES MANUAL MODAL OVERLAY -->\n    <div id=\"rules-modal\" class=\"hidden fixed inset-0 bg-black/85 backdrop-blur-sm flex items-center justify-center p-4 z-50 transition-all duration-300\">\n      <div class=\"bg-zinc-900 border border-zinc-800 rounded-lg w-full max-w-2xl max-h-[85vh] flex flex-col shadow-[0_0_50px_rgba(139,92,246,0.15)]\">\n        <!-- Header -->\n        <div class=\"p-5 border-b border-zinc-800 flex items-center justify-between\">\n          <div class=\"flex items-center gap-3\">\n            <span class=\"w-2.5 h-2.5 bg-purple-500 rounded-full\"></span>\n            <div>\n              <h3 class=\"font-display font-bold text-zinc-100 uppercase tracking-widest text-sm\">Culling Game Declarative Rules</h3>\n              <p class=\"text-zinc-500 font-mono text-[10px] uppercase\">The binding vow governing Kenjaku\'s game board</p>\n            </div>\n          </div>\n          <button onclick=\"closeRulesModal()\" class=\"text-zinc-500 hover:text-zinc-200 transition p-1\">\n            <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M6 18L18 6M6 6l12 12\" /></svg>\n          </button>\n        </div>\n        <!-- Content -->\n        <div class=\"p-6 overflow-y-auto scrollbar-thin space-y-4 text-xs font-mono leading-relaxed text-zinc-400\">\n          <p class=\"text-zinc-300 italic mb-3\">\"Players are given points by killing other sorcerers. Points correspond to the life of J\305\253jutsu Sorcerers or Non-Sorcerers...\"</p>\n          \n          <div class=\"space-y-3.5\">\n            <div>\n              <span class=\"text-purple-400 font-bold block mb-1\">RULE 1 \342\200\242 DECLARATIVE PARTICIPATION</span>\n              <p>Upon gaining a cursed technique or waking up inside a barrier, players must declare participation in the Culling Game in their starting colony within 19 days.</p>\n            </div>\n            <div class=\"h-px bg-zinc-800/80\"></div>\n            <div>\n              <span class=\"text-purple-400 font-bold block mb-1\">RULE 2 \342\200\242 PENALTY OF DEATH</span>\n              <p>Any player who breaks Rule 1 shall suffer cursed technique extraction, which inevitably results in immediate brain death and cardiac arrest.</p>\n            </div>\n            <div class=\"h-px bg-zinc-800/80\"></div>\n            <div>\n              <span class=\"text-purple-400 font-bold block mb-1\">RULE 5 \342\200\242 ACQUIRING POINTS</span>\n              <p>Players obtain points by taking the life of other participants. Shaman/Sorcerer deaths yield 5 points. Non-shaman deaths yield 1 point.</p>\n            </div>\n            <div class=\"h-px bg-zinc-800/80\"></div>\n            <div>\n              <span class=\"text-purple-400 font-bold block mb-1\">RULE 10 \342\200\242 POINT TRANSFER</span>\n              <p>Players may transfer any number of their points to another participant. Koganes will act as the intermediary agent for all score adjustments.</p>\n            </div>\n            <div class=\"h-px bg-zinc-800/80\"></div>\n            <div>\n              <span class=\"text-purple-400 font-bold block mb-1\">RULE 11 \342\200\242 CUSTOM RULE ADDITION</span>\n              <p>Except where it would have a significant negative impact on the longevity of the game, players may spend 100 points to negotiate and add a new rule to the Game Board with their Kogane.</p>\n            </div>\n          </div>\n        </div>\n        <!-- Footer -->\n        <div class=\"p-4 bg-zinc-950 border-t border-zinc-800 flex justify-end\">\n          <button onclick=\"closeRulesModal()\" class=\"px-5 py-2 bg-zinc-800 hover:bg-zinc-700 text-zinc-200 rounded font-mono text-xs uppercase tracking-wider transition\">Acknowledge Rules</button>\n        </div>\n      </div>\n    </div>\n\n    <!-- MAIN ENGINE CODE -->\n    <script>\n      // -------------------------------------------------------------\n      // 1. Initial Seed Data\n      // -------------------------------------------------------------\n      const initialPlayers = [\n        { id: \"1\", name: \"Yuta Okkotsu\", colony: \"Sendai Colony\", technique: \"Copy / Rika Manifestation\", points: 190, status: \"Alive\" },\n        { id: \"2\", name: \"Hajime Kashimo\", colony: \"Tokyo Colony No. 2\", technique: \"Phantom Beast Amber (Electrification)\", points: 200, status: \"Alive\" },\n        { id: \"3\", name: \"Hiromi Higuruma\", colony: \"Tokyo Colony No. 1\", technique: \"Deadly Sentencing (Domain Expansion)\", points: 100, status: \"Alive\" },\n        { id: \"4\", name: \"Megumi Fushiguro\", colony: \"Tokyo Colony No. 1\", technique: \"Ten Shadows Technique\", points: 40, status: \"Alive\" },\n        { id: \"5\", name: \"Yuji Itadori\", colony: \"Tokyo Colony No. 1\", technique: \"Divergent Fist / Shrine\", points: 1, status: \"Alive\" },\n        { id: \"6\", name: \"Reggie Star\", colony: \"Tokyo Colony No. 1\", technique: \"Contract Re-creation\", points: 41, status: \"Deceased\" },\n        { id: \"7\", name: \"Ryu Ishigori\", colony: \"Sendai Colony\", technique: \"Granite Blast (Cursed Energy Discharge)\", points: 77, status: \"Deceased\" },\n        { id: \"8\", name: \"Takako Uro\", colony: \"Sendai Colony\", technique: \"Sky Manipulation\", points: 70, status: \"Alive\" },\n        { id: \"9\", name: \"Kurourushi\", colony: \"Sendai Colony\", technique: \"Parthenogenesis / Earth-Buster Cockroach\", points: 54, status: \"Deceased\" }\n      ];\n\n      // -------------------------------------------------------------\n      // 2. Global State Variables\n      // -------------------------------------------------------------\n      let players = [];\n      let currentLeftTab = \'register\'; // \'register\' or \'transfer\'\n      let currentStatusFilter = \'ALL\'; // \'ALL\', \'Alive\', \'Deceased\'\n\n      // -------------------------------------------------------------\n      // 3. Application Lifecycle Setup\n      // -------------------------------------------------------------\n      window.onload = function() {\n        // Load data from localStorage or seed database if empty\n        const storedPlayers = localStorage.getItem(\'culling_games_sorcerers\');\n        if (storedPlayers) {\n          try {\n            players = JSON.parse(storedPlayers);\n          } catch(e) {\n            players = [...initialPlayers];\n          }\n        } else {\n          players = [...initialPlayers];\n          localStorage.setItem(\'culling_games_sorcerers\', JSON.stringify(players));\n        }\n\n        // Initialize display components\n        addLog(\"KOGANE MONITORING ENGINE STABLE. Handshake established.\", \"system\");\n        addLog(`LOADED: ${players.length} active combatant profiles found.`, \"info\");\n        \n        // Refresh entire UI\n        updateUI();\n        \n        // Start live ticking clock\n        startClock();\n      };\n\n      // -------------------------------------------------------------\n      // 4. Persistence & UI Sync\n      // -------------------------------------------------------------\n      function saveToStorage() {\n        localStorage.setItem(\'culling_games_sorcerers\', JSON.stringify(players));\n      }\n\n      function updateUI() {\n        renderPlayers();\n        renderStats();\n        populateTransferSelects();\n      }\n\n      // -------------------------------------------------------------\n      // 5. Clock Ticker\n      // -------------------------------------------------------------\n      function startClock() {\n        const systemClockEl = document.getElementById(\'system-clock\');\n        setInterval(() => {\n          const now = new Date();\n          const formatStr = now.toISOString().replace(\'T\', \' \').substring(0, 19) + \' UTC\';\n          systemClockEl.innerText = formatStr;\n        }, 1000);\n      }\n\n      // -------------------------------------------------------------\n      // 6. Kogane Broadcast Logs Feed\n      // -------------------------------------------------------------\n      function addLog(text, type = \"info\") {\n        const logsContainer = document.getElementById(\'logs-container\');\n        const now = new Date();\n        const timeStr = now.toTimeString().split(\' \')[0];\n        \n        let colorClass = \"text-zinc-500\";\n        let prefix = \"\342\227\217\";\n\n        if (type === \"system\") {\n          colorClass = \"text-purple-400 font-bold\";\n          prefix = \"\342\232\241 [SYS]\";\n        } else if (type === \"success\") {\n          colorClass = \"text-emerald-400\";\n          prefix = \"\342\234\224 [KOG]\";\n        } else if (type === \"danger\") {\n          colorClass = \"text-red-500\";\n          prefix = \"\342\230\240 [DEAD]\";\n        } else if (type === \"transfer\") {\n          colorClass = \"text-yellow-400\";\n          prefix = \"\342\207\204 [PTS]\";\n        } else if (type === \"info\") {\n          colorClass = \"text-zinc-400\";\n          prefix = \"\342\204\271 [INFO]\";\n        }\n\n        const logItem = document.createElement(\'div\');\n        logItem.className = `flex items-start gap-1.5 ${colorClass} leading-tight border-b border-zinc-900 pb-1`;\n        logItem.innerHTML = `\n          <span class=\"text-[9px] text-zinc-600 shrink-0 font-mono\">${timeStr}</span>\n          <span class=\"shrink-0 text-[10px]\">${prefix}</span>\n          <span class=\"break-words\">${text}</span>\n        `;\n        \n        logsContainer.appendChild(logItem);\n        logsContainer.scrollTop = logsContainer.scrollHeight;\n      }\n\n      function clearLogs() {\n        document.getElementById(\'logs-container\').innerHTML = \'\';\n        addLog(\"Kogane broadcast memory purged.\", \"system\");\n      }\n\n      // -------------------------------------------------------------\n      // 7. Left Panel Tab Switching\n      // -------------------------------------------------------------\n      function switchLeftTab(tab) {\n        currentLeftTab = tab;\n        const regBtn = document.getElementById(\'tab-register-btn\');\n        const transBtn = document.getElementById(\'tab-transfer-btn\');\n        const regPanel = document.getElementById(\'left-tab-register\');\n        const transPanel = document.getElementById(\'left-tab-transfer\');\n\n        if (tab === \'register\') {\n          regBtn.className = \"flex-1 py-3 text-center border-b-2 border-purple-500 text-purple-400 font-bold bg-zinc-900/50 transition\";\n          transBtn.className = \"flex-1 py-3 text-center border-b-2 border-transparent text-zinc-500 hover:text-zinc-300 transition\";\n          regPanel.classList.remove(\'hidden\');\n          transPanel.classList.add(\'hidden\');\n        } else {\n          transBtn.className = \"flex-1 py-3 text-center border-b-2 border-purple-500 text-purple-400 font-bold bg-zinc-900/50 transition\";\n          regBtn.className = \"flex-1 py-3 text-center border-b-2 border-transparent text-zinc-500 hover:text-zinc-300 transition\";\n          transPanel.classList.remove(\'hidden\');\n          regPanel.classList.add(\'hidden\');\n          populateTransferSelects();\n        }\n      }\n\n      // -------------------------------------------------------------\n      // 8. Player Rendering & Grid Engine\n      // -------------------------------------------------------------\n      function renderPlayers() {\n        const grid = document.getElementById(\'players-grid\');\n        const emptyState = document.getElementById(\'empty-state\');\n        grid.innerHTML = \'\';\n\n        const searchVal = document.getElementById(\'search-input\').value.toLowerCase().trim();\n        const colonyFilter = document.getElementById(\'filter-colony\').value;\n\n        // Apply filters\n        const filteredPlayers = players.filter(player => {\n          // Name or technique match\n          const matchesSearch = player.name.toLowerCase().includes(searchVal) || \n                                (player.technique && player.technique.toLowerCase().includes(searchVal));\n          \n          // Colony match\n          const matchesColony = (colonyFilter === \'ALL\' || player.colony === colonyFilter);\n          \n          // Status match\n          const matchesStatus = (currentStatusFilter === \'ALL\' || player.status === currentStatusFilter);\n\n          return matchesSearch && matchesColony && matchesStatus;\n        });\n\n        if (filteredPlayers.length === 0) {\n          grid.classList.add(\'hidden\');\n          emptyState.classList.remove(\'hidden\');\n          return;\n        }\n\n        grid.classList.remove(\'hidden\');\n        emptyState.classList.add(\'hidden\');\n\n        filteredPlayers.forEach(player => {\n          const isAlive = player.status === \"Alive\";\n          \n          const card = document.createElement(\'div\');\n          card.className = `group bg-zinc-900 border ${isAlive ? \'border-zinc-800/80 hover:border-purple-600/60\' : \'border-zinc-800 opacity-60 hover:opacity-85\'} rounded-lg overflow-hidden transition-all duration-300 hover:shadow-[0_0_20px_rgba(139,92,246,0.12)] flex flex-col h-full`;\n          \n          card.innerHTML = `\n            <!-- Card Header -->\n            <div class=\"px-4.5 py-3 border-b border-zinc-800/80 flex items-center justify-between bg-zinc-900/40 p-4\">\n              <div class=\"flex items-center gap-2\">\n                <span class=\"w-2.5 h-2.5 rounded-full ${isAlive ? \'bg-emerald-500 active-pulse\' : \'bg-red-500\'}\"></span>\n                <span class=\"font-display font-bold text-zinc-100 group-hover:text-purple-300 transition duration-300 ${isAlive ? \'\' : \'line-through text-zinc-500\'}\">${player.name}</span>\n              </div>\n              <button \n                onclick=\"toggleLifeStatus(\'${player.id}\')\" \n                class=\"px-2 py-0.5 rounded text-[9px] font-mono uppercase tracking-widest border transition duration-200 ${isAlive ? \'bg-emerald-950/20 border-emerald-900/50 text-emerald-400 hover:bg-emerald-900/35\' : \'bg-red-950/20 border-red-900/50 text-red-400 hover:bg-red-900/35\'}\"\n                title=\"Toggle Life Status\"\n              >\n                ${player.status}\n              </button>\n            </div>\n\n            <!-- Card Body -->\n            <div class=\"p-4 flex-1 flex flex-col justify-between space-y-4\">\n              <div>\n                <!-- Colony Badge -->\n                <div class=\"font-mono text-[9px] uppercase tracking-widest text-zinc-400 font-bold flex items-center gap-1.5 mb-2.5\">\n                  <span class=\"w-1.5 h-1.5 bg-purple-600 rounded\"></span> ${player.colony}\n                </div>\n                <!-- Technique Description -->\n                <p class=\"text-zinc-400 text-xs leading-normal bg-zinc-950/40 border border-zinc-850 p-2.5 rounded font-sans min-h-[48px]\">\n                  ${player.technique ? player.technique : \'<span class=\"text-zinc-600 italic\">No declared Cursed Technique</span>\'}\n                </p>\n              </div>\n\n              <!-- Point Layout -->\n              <div class=\"flex items-end justify-between pt-2 border-t border-zinc-850/60\">\n                <div class=\"flex flex-col\">\n                  <span class=\"text-zinc-500 font-mono text-[9px] uppercase tracking-wider\">Culling Points</span>\n                  <div class=\"flex items-baseline gap-1\">\n                    <span class=\"font-mono font-bold text-3xl tracking-tight ${isAlive ? \'text-purple-400\' : \'text-zinc-500\'}\">${player.points}</span>\n                    <span class=\"text-[10px] font-mono text-zinc-500 font-bold uppercase\">PTS</span>\n                  </div>\n                </div>\n\n                <!-- Footer Quick Controls (+1, -1, Delete) -->\n                <div class=\"flex items-center gap-1\">\n                  <!-- Subtract Button -->\n                  <button \n                    onclick=\"adjustPoints(\'${player.id}\', -1)\"\n                    class=\"p-1.5 bg-zinc-850 hover:bg-zinc-800 text-zinc-400 hover:text-zinc-100 border border-zinc-800 rounded transition cursor-pointer\"\n                    title=\"Deduct 1 Point\"\n                  >\n                    <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M19 12H5\" /></svg>\n                  </button>\n\n                  <!-- Add Button -->\n                  <button \n                    onclick=\"adjustPoints(\'${player.id}\', 1)\"\n                    class=\"p-1.5 bg-zinc-850 hover:bg-zinc-800 text-zinc-400 hover:text-zinc-100 border border-zinc-800 rounded transition cursor-pointer\"\n                    title=\"Add 1 Point\"\n                  >\n                    <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 4v16m8-8H4\" /></svg>\n                  </button>\n\n                  <!-- Delete Player -->\n                  <button \n                    onclick=\"deletePlayer(\'${player.id}\')\"\n                    class=\"p-1.5 bg-zinc-850/30 hover:bg-red-950/40 text-zinc-600 hover:text-red-400 border border-transparent hover:border-red-900/50 rounded transition ml-1.5 cursor-pointer\"\n                    title=\"Eradicate Sorcerer\"\n                  >\n                    <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\" /></svg>\n                  </button>\n                </div>\n              </div>\n            </div>\n          `;\n          \n          grid.appendChild(card);\n        });\n      }\n\n      // -------------------------------------------------------------\n      // 9. Stats Generator\n      // -------------------------------------------------------------\n      function renderStats() {\n        const totalPlayers = players.length;\n        const totalPoints = players.reduce((sum, p) => sum + p.points, 0);\n        const totalDeceased = players.filter(p => p.status === \"Deceased\").length;\n        \n        // Calculate Mortality rate\n        const mortalityRate = totalPlayers > 0 ? Math.round((totalDeceased / totalPlayers) * 100) : 0;\n\n        document.getElementById(\'stat-total-players\').innerText = totalPlayers;\n        document.getElementById(\'stat-total-points\').innerText = totalPoints;\n        document.getElementById(\'stat-mortality-rate\').innerText = `${mortalityRate}%`;\n      }\n\n      // -------------------------------------------------------------\n      // 10. Filter Handler Actions\n      // -------------------------------------------------------------\n      function handleFilterChange() {\n        renderPlayers();\n      }\n\n      function setStatusFilter(status) {\n        currentStatusFilter = status;\n        \n        // Update Filter tabs styling\n        const allBtn = document.getElementById(\'filter-status-all\');\n        const aliveBtn = document.getElementById(\'filter-status-alive\');\n        const deceasedBtn = document.getElementById(\'filter-status-deceased\');\n\n        const inactiveClass = \"px-3.5 py-1.5 rounded text-zinc-400 hover:text-zinc-200 transition\";\n        const activeClass = \"px-3.5 py-1.5 rounded text-purple-400 bg-zinc-850 font-bold transition\";\n\n        allBtn.className = inactiveClass;\n        aliveBtn.className = inactiveClass;\n        deceasedBtn.className = inactiveClass;\n\n        if (status === \'ALL\') allBtn.className = activeClass;\n        else if (status === \'Alive\') aliveBtn.className = activeClass;\n        else if (status === \'Deceased\') deceasedBtn.className = activeClass;\n\n        renderPlayers();\n      }\n\n      // -------------------------------------------------------------\n      // 11. Sorcerer Registration (Form Submit)\n      // -------------------------------------------------------------\n      function registerPlayer(e) {\n        e.preventDefault();\n\n        const nameInput = document.getElementById(\'reg-name\');\n        const colonySelect = document.getElementById(\'reg-colony\');\n        const techInput = document.getElementById(\'reg-technique\');\n        const pointsInput = document.getElementById(\'reg-points\');\n        const statusSelect = document.getElementById(\'reg-status\');\n\n        const newSorcerer = {\n          id: Date.now().toString(),\n          name: nameInput.value.trim(),\n          colony: colonySelect.value,\n          technique: techInput.value.trim() || \"\",\n          points: parseInt(pointsInput.value, 10) || 0,\n          status: statusSelect.value\n        };\n\n        // Add to array\n        players.unshift(newSorcerer);\n        \n        // Save & Sync\n        saveToStorage();\n        updateUI();\n\n        // Broadcast Log\n        addLog(`DECLARATION: ${newSorcerer.name} entered ${newSorcerer.colony}. Cursed technique synchronized.`, \"success\");\n\n        // Clear Form fields\n        nameInput.value = \'\';\n        techInput.value = \'\';\n        pointsInput.value = \'0\';\n        statusSelect.value = \'Alive\';\n\n        // Scroll grid back to top to show newly added card\n        document.getElementById(\'players-grid\').scrollIntoView({ behavior: \'smooth\' });\n      }\n\n      // -------------------------------------------------------------\n      // 12. Adjust Individual Points\n      // -------------------------------------------------------------\n      function adjustPoints(id, amount) {\n        const playerIndex = players.findIndex(p => p.id === id);\n        if (playerIndex === -1) return;\n\n        const player = players[playerIndex];\n        const oldPoints = player.points;\n        const newPoints = Math.max(0, player.points + amount);\n\n        if (oldPoints === newPoints) return; // No change\n\n        players[playerIndex].points = newPoints;\n        saveToStorage();\n        updateUI();\n\n        addLog(`Rule #10 Adjust: Kogane synchronized ${player.name}\'s points (${oldPoints} PTS \342\236\224 ${newPoints} PTS).`, \"transfer\");\n      }\n\n      // -------------------------------------------------------------\n      // 13. Life/Death Status Toggle\n      // -------------------------------------------------------------\n      function toggleLifeStatus(id) {\n        const playerIndex = players.findIndex(p => p.id === id);\n        if (playerIndex === -1) return;\n\n        const player = players[playerIndex];\n        const newStatus = player.status === \"Alive\" ? \"Deceased\" : \"Alive\";\n        \n        players[playerIndex].status = newStatus;\n        saveToStorage();\n        updateUI();\n\n        if (newStatus === \"Deceased\") {\n          addLog(`DEATH NOTIFICATION: Sorcerer ${player.name} eradicated in combat.`, \"danger\");\n        } else {\n          addLog(`RESTORATION: Sorcerer ${player.name} reconstructed via Reverse Cursed Technique.`, \"success\");\n        }\n      }\n\n      // -------------------------------------------------------------\n      // 14. Eliminate Sorcerer (Delete)\n      // -------------------------------------------------------------\n      function deletePlayer(id) {\n        const player = players.find(p => p.id === id);\n        if (!player) return;\n\n        if (confirm(`Eradicate all Kogane telemetry data for \"${player.name}\"? This cannot be undone.`)) {\n          players = players.filter(p => p.id !== id);\n          saveToStorage();\n          updateUI();\n          addLog(`SYSTEM: ${player.name} registry deleted. All Kogane traces vaporized.`, \"danger\");\n        }\n      }\n\n      // -------------------------------------------------------------\n      // 15. Point Transfer Simulation Engine\n      // -------------------------------------------------------------\n      function populateTransferSelects() {\n        const senderSelect = document.getElementById(\'trans-sender\');\n        const receiverSelect = document.getElementById(\'trans-receiver\');\n        \n        if (!senderSelect || !receiverSelect) return;\n\n        senderSelect.innerHTML = \'\';\n        receiverSelect.innerHTML = \'\';\n\n        // Only alive sorcerers who have points are recommended for sender (though anyone alive can theoretically transfer)\n        const eligibleSenders = players.filter(p => p.status === \"Alive\");\n        const eligibleReceivers = players.filter(p => p.status === \"Alive\");\n\n        if (eligibleSenders.length === 0) {\n          senderSelect.innerHTML = \'<option value=\"\">No Active Sorcerers</option>\';\n          receiverSelect.innerHTML = \'<option value=\"\">No Active Sorcerers</option>\';\n          return;\n        }\n\n        eligibleSenders.forEach(p => {\n          const opt = document.createElement(\'option\');\n          opt.value = p.id;\n          opt.innerText = `${p.name} (${p.points} Pts)`;\n          senderSelect.appendChild(opt);\n        });\n\n        eligibleReceivers.forEach(p => {\n          const opt = document.createElement(\'option\');\n          opt.value = p.id;\n          opt.innerText = p.name;\n          receiverSelect.appendChild(opt);\n        });\n\n        // Set non-overlapping defaults if possible\n        if (senderSelect.options.length > 1) {\n          receiverSelect.selectedIndex = 1;\n        }\n      }\n\n      function simulateTransfer(e) {\n        e.preventDefault();\n\n        const senderId = document.getElementById(\'trans-sender\').value;\n        const receiverId = document.getElementById(\'trans-receiver\').value;\n        const amountInput = document.getElementById(\'trans-amount\');\n        const amount = parseInt(amountInput.value, 10);\n\n        if (!senderId || !receiverId) {\n          alert(\"Must select both a sender and a receiver.\");\n          return;\n        }\n\n        if (senderId === receiverId) {\n          alert(\"A participant cannot transfer points to themselves under Game Rule #10.\");\n          return;\n        }\n\n        const senderIndex = players.findIndex(p => p.id === senderId);\n        const receiverIndex = players.findIndex(p => p.id === receiverId);\n\n        if (senderIndex === -1 || receiverIndex === -1) return;\n\n        const sender = players[senderIndex];\n        const receiver = players[receiverIndex];\n\n        if (sender.points < amount) {\n          alert(`Insufficient Points. ${sender.name} only has ${sender.points} points, but you are attempting to transfer ${amount}.`);\n          return;\n        }\n\n        // Deduct & Add\n        players[senderIndex].points -= amount;\n        players[receiverIndex].points += amount;\n\n        saveToStorage();\n        updateUI();\n\n        addLog(`POINT TRANSFER COMPLETE: ${sender.name} sent ${amount} PTS to ${receiver.name}. Approved by Kogane.`, \"transfer\");\n\n        // Reset points amount value\n        amountInput.value = \'1\';\n\n        // Pop up alert or animate confirmation\n        alert(`Rule #10 Enforced!\\n${amount} points successfully transferred from ${sender.name} to ${receiver.name}.`);\n      }\n\n      // -------------------------------------------------------------\n      // 16. Reset System\n      // -------------------------------------------------------------\n      function resetSystem() {\n        if (confirm(\"Restore the monitoring panel to initial game registry state? All custom-registered sorcerers and point modifications will be purged.\")) {\n          players = [...initialPlayers];\n          saveToStorage();\n          updateUI();\n          \n          // Reset filters\n          document.getElementById(\'search-input\').value = \'\';\n          document.getElementById(\'filter-colony\').value = \'ALL\';\n          setStatusFilter(\'ALL\');\n\n          clearLogs();\n          addLog(\"SYSTEM RESTORED. Initial Culling Game contestant matrix re-loaded.\", \"system\");\n        }\n      }\n\n      // -------------------------------------------------------------\n      // 17. Rules Modal Overlay Controls\n      // -------------------------------------------------------------\n      function openRulesModal() {\n        document.getElementById(\'rules-modal\').classList.remove(\'hidden\');\n      }\n\n      function closeRulesModal() {\n        document.getElementById(\'rules-modal\').classList.add(\'hidden\');\n      }\n    </script>\n  </body>\n</html>\n"
    }
