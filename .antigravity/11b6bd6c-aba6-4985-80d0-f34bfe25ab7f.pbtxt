        lines {
          text: "        const eligibleReceivers = players.filter(p => p.status === \"Alive\");"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (eligibleSenders.length === 0) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          senderSelect.innerHTML = \'<option value=\"\">No Active Sorcerers</option>\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          receiverSelect.innerHTML = \'<option value=\"\">No Active Sorcerers</option>\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          return;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        eligibleSenders.forEach(p => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          const opt = document.createElement(\'option\');"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
