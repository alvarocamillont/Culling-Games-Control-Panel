          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        { id: \"7\", name: \"Ryu Ishigori\", colony: \"Sendai Colony\", technique: \"Granite Blast (Cursed Energy Discharge)\", points: 77, status: \"Deceased\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        { id: \"8\", name: \"Takako Uro\", colony: \"Sendai Colony\", technique: \"Sky Manipulation\", points: 70, status: \"Alive\" },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        { id: \"9\", name: \"Kurourushi\", colony: \"Sendai Colony\", technique: \"Parthenogenesis / Earth-Buster Cockroach\", points: 54, status: \"Deceased\" }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      ];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // -------------------------------------------------------------"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // 2. Global State Variables"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // -------------------------------------------------------------"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      let players = [];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      let currentLeftTab = \'register\'; // \'register\' or \'transfer\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      let currentStatusFilter = \'ALL\'; // \'ALL\', \'Alive\', \'Deceased\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
