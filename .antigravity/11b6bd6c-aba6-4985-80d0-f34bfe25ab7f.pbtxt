        }
        lines {
          text: "        const receiverIndex = players.findIndex(p => p.id === receiverId);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
