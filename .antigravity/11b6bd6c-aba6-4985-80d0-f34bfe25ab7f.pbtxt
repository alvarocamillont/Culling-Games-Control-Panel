          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Only alive sorcerers who have points are recommended for sender (though anyone alive can theoretically transfer)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
