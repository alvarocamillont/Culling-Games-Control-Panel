    instruction: "Apply Immersive UI style to player cards generated in Javascript"
    replacement_infos {
      original_chunk {
        target_content: "        filteredPlayers.forEach(player => {\n          const isAlive = player.status === \"Alive\";\n          \n          const card = document.createElement(\'div\');\n          card.className = `group bg-zinc-900 border ${isAlive ? \'border-zinc-800/80 hover:border-purple-600/60\' : \'border-zinc-800 opacity-60 hover:opacity-85\'} rounded-lg overflow-hidden transition-all duration-300 hover:shadow-[0_0_20px_rgba(139,92,246,0.12)] flex flex-col h-full`;\n          \n          card.innerHTML = `\n            <!-- Card Header -->\n            <div class=\"px-4.5 py-3 border-b border-zinc-800/80 flex items-center justify-between bg-zinc-900/40 p-4\">\n              <div class=\"flex items-center gap-2\">\n                <span class=\"w-2.5 h-2.5 rounded-full ${isAlive ? \'bg-emerald-500 active-pulse\' : \'bg-red-500\'}\"></span>\n                <span class=\"font-display font-bold text-zinc-100 group-hover:text-purple-300 transition duration-300 ${isAlive ? \'\' : \'line-through text-zinc-500\'}\">${player.name}</span>\n              </div>\n              <button \n                onclick=\"toggleLifeStatus(\'${player.id}\')\" \n                class=\"px-2 py-0.5 rounded text-[9px] font-mono uppercase tracking-widest border transition duration-200 ${isAlive ? \'bg-emerald-950/20 border-emerald-900/50 text-emerald-400 hover:bg-emerald-900/35\' : \'bg-red-950/20 border-red-900/50 text-red-400 hover:bg-red-900/35\'}\"\n                title=\"Toggle Life Status\"\n              >\n                ${player.status}\n              </button>\n            </div>\n\n            <!-- Card Body -->\n            <div class=\"p-4 flex-1 flex flex-col justify-between space-y-4\">\n              <div>\n                <!-- Colony Badge -->\n                <div class=\"font-mono text-[9px] uppercase tracking-widest text-zinc-400 font-bold flex items-center gap-1.5 mb-2.5\">\n                  <span class=\"w-1.5 h-1.5 bg-purple-600 rounded\"></span> ${player.colony}\n                </div>\n                <!-- Technique Description -->\n                <p class=\"text-zinc-400 text-xs leading-normal bg-zinc-950/40 border border-zinc-850 p-2.5 rounded font-sans min-h-[48px]\">\n                  ${player.technique ? player.technique : \'<span class=\"text-zinc-600 italic\">No declared Cursed Technique</span>\'}\n                </p>\n              </div>\n\n              <!-- Point Layout -->\n              <div class=\"flex items-end justify-between pt-2 border-t border-zinc-850/60\">\n                <div class=\"flex flex-col\">\n                  <span class=\"text-zinc-500 font-mono text-[9px] uppercase tracking-wider\">Culling Points</span>\n                  <div class=\"flex items-baseline gap-1\">\n                    <span class=\"font-mono font-bold text-3xl tracking-tight ${isAlive ? \'text-purple-400\' : \'text-zinc-500\'}\">${player.points}</span>\n                    <span class=\"text-[10px] font-mono text-zinc-500 font-bold uppercase\">PTS</span>\n                  </div>\n                </div>\n\n                <!-- Footer Quick Controls (+1, -1, Delete) -->\n                <div class=\"flex items-center gap-1\">\n                  <!-- Subtract Button -->\n                  <button \n                    onclick=\"adjustPoints(\'${player.id}\', -1)\"\n                    class=\"p-1.5 bg-zinc-850 hover:bg-zinc-800 text-zinc-400 hover:text-zinc-100 border border-zinc-800 rounded transition cursor-pointer\"\n                    title=\"Deduct 1 Point\"\n                  >\n                    <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M19 12H5\" /></svg>\n                  </button>\n\n                  <!-- Add Button -->\n                  <button \n                    onclick=\"adjustPoints(\'${player.id}\', 1)\"\n                    class=\"p-1.5 bg-zinc-850 hover:bg-zinc-800 text-zinc-400 hover:text-zinc-100 border border-zinc-800 rounded transition cursor-pointer\"\n                    title=\"Add 1 Point\"\n                  >\n                    <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 4v16m8-8H4\" /></svg>\n                  </button>\n\n                  <!-- Delete Player -->\n                  <button \n                    onclick=\"deletePlayer(\'${player.id}\')\"\n                    class=\"p-1.5 bg-zinc-850/30 hover:bg-red-950/40 text-zinc-600 hover:text-red-400 border border-transparent hover:border-red-900/50 rounded transition ml-1.5 cursor-pointer\"\n                    title=\"Eradicate Sorcerer\"\n                  >\n                    <svg class=\"w-3.5 h-3.5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\" /></svg>\n                  </button>\n                </div>\n              </div>\n            </div>\n          `;\n          \n          grid.appendChild(card);\n        });"
        replacement_content: "        filteredPlayers.forEach(player => {\n          const isAlive = player.status === \"Alive\";\n          \n          const card = document.createElement(\'div\');\n          card.className = `bg-zinc-900 border border-zinc-800 p-5 rounded-lg flex flex-col shadow-lg border-l-4 ${isAlive ? \'border-l-emerald-500 hover:border-purple-600/60\' : \'border-l-red-500 opacity-65 hover:opacity-85\'} transition-all duration-300 hover:shadow-[0_0_20px_rgba(139,92,246,0.12)]`;\n          \n          card.innerHTML = `\n            <!-- Card Header -->\n            <div class=\"flex justify-between items-start mb-2\">\n              <h3 class=\"text-zinc-100 font-bold text-base ${isAlive ? \'\' : \'line-through text-zinc-500\'}\">${player.name}</h3>\n              <button \n                onclick=\"toggleLifeStatus(\'${player.id}\')\" \n                class=\"flex items-center gap-1.5 px-2.5 py-1 rounded text-[9px] font-mono uppercase tracking-widest border transition duration-200 cursor-pointer ${isAlive ? \'bg-emerald-950/20 border-emerald-900/50 text-emerald-400 hover:bg-emerald-900/35\' : \'bg-red-950/20 border-red-900/50 text-red-400 hover:bg-red-900/35\'}\"\n                title=\"Toggle Life Status\"\n              >\n                <span class=\"w-1.5 h-1.5 rounded-full ${isAlive ? \'bg-emerald-400 active-pulse\' : \'bg-red-500\'}\"></span>\n                <span>${player.status}</span>\n              </button>\n            </div>\n\n            <!-- Colony Title -->\n            <span class=\"text-[9px] uppercase text-zinc-500 tracking-widest mb-3 block font-mono\">\n              ${player.colony}\n            </span>\n\n            <!-- Technique Specification -->\n            <p class=\"text-zinc-400 text-xs leading-normal bg-zinc-950/40 border border-zinc-850/80 p-2.5 rounded font-sans min-h-[48px] mb-4\">\n              ${player.technique ? player.technique : \'<span class=\"text-zinc-600 italic\">No declared Cursed Technique</span>\'}\n            </p>\n\n            <!-- Point Display and quick actions -->\n            <div class=\"mt-auto pt-4 border-t border-zinc-800/60 flex items-center justify-between\">\n              <div>\n                <span class=\"text-[9px] uppercase text-zinc-500 tracking-widest block font-mono\">Points</span>\n                <div class=\"text-3xl font-mono ${isAlive ? \'text-purple-400\' : \'text-zinc-600\'} font-black\">${player.points}</div>\n              </div>\n              \n              <div class=\"flex items-center gap-1\">\n                ${isAlive ? `\n                  <button \n                    onclick=\"adjustPoints(\'${player.id}\', -1)\"\n                    class=\"bg-zinc-950 border border-zinc-800 hover:bg-zinc-800 text-zinc-400 hover:text-zinc-250 px-2.5 py-1.5 rounded text-[10px] font-mono transition cursor-pointer\"\n                    title=\"-1 Point\"\n                  >\n                    -1 PTS\n                  </button>\n                  <button \n                    onclick=\"adjustPoints(\'${player.id}\', 1)\"\n                    class=\"bg-zinc-950 border border-zinc-800 hover:bg-zinc-850 text-purple-400 hover:text-purple-300 px-2.5 py-1.5 rounded text-[10px] font-mono transition cursor-pointer\"\n                    title=\"+1 Point\"\n                  >\n                    +1 PTS\n                  </button>\n                ` : `\n                  <button \n                    class=\"bg-zinc-950/50 border border-zinc-800/50 px-4 py-1.5 rounded text-[10px] font-mono text-zinc-700 cursor-not-allowed uppercase\"\n                    disabled\n                  >\n                    LOCKED\n                  </button>\n                `}\n                \n                <!-- Eradicate/Delete Button -->\n                <button \n                  onclick=\"deletePlayer(\'${player.id}\')\"\n                  class=\"bg-zinc-950 border border-zinc-800 hover:border-red-950/60 hover:text-red-400 text-zinc-600 p-1.5 rounded transition cursor-pointer\"\n                  title=\"Eradicate Sorcerer\"\n                >\n                  <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\" /></svg>\n                </button>\n              </div>\n            </div>\n          `;\n          \n          grid.appendChild(card);\n        });"
      }
      num_matches: 1
    }
  }
