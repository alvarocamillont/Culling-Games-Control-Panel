    }
    instruction: "Apply Immersive UI style to left panel content, inputs, tabs, logs, and top stats bar"
    replacement_infos {
      original_chunk {
        target_content: "      <!-- LEFT PANEL: REGISTRATION ZONE & LOGS (30% width) -->\n      <section class=\"w-full md:w-[32%] lg:w-[28%] bg-zinc-900 border-r border-zinc-800 flex flex-col h-full overflow-hidden shrink-0\">\n        \n        <!-- Tab Selectors for Left Side -->\n        <div class=\"flex border-b border-zinc-800 font-mono text-xs uppercase shrink-0\">\n          <button id=\"tab-register-btn\" onclick=\"switchLeftTab(\'register\')\" class=\"flex-1 py-3 text-center border-b-2 border-purple-500 text-purple-400 font-bold bg-zinc-900/50 transition\">\n            Participation\n          </button>\n          <button id=\"tab-transfer-btn\" onclick=\"switchLeftTab(\'transfer\')\" class=\"flex-1 py-3 text-center border-b-2 border-transparent text-zinc-500 hover:text-zinc-300 transition\">\n            Point Transfer\n          </button>\n        </div>\n\n        <!-- Scrollable content area -->\n        <div class=\"flex-1 overflow-y-auto p-5 scrollbar-thin space-y-6\">\n\n          <!-- TAB 1: REGISTRATION FORM -->\n          <div id=\"left-tab-register\" class=\"space-y-5\">\n            <div>\n              <h2 class=\"font-display font-bold text-zinc-200 text-sm tracking-widest uppercase mb-1\">Sorcerer Registration</h2>\n              <p class=\"text-zinc-500 font-mono text-[11px] uppercase\">Submit credentials to authorize a new game participant.</p>\n            </div>\n\n            <form id=\"registration-form\" onsubmit=\"registerPlayer(event)\" class=\"space-y-4\">\n              <!-- Name field -->\n              <div class=\"space-y-1.5\">\n                <label for=\"reg-name\" class=\"block font-mono text-[11px] uppercase tracking-wider text-zinc-400 font-semibold\">Sorcerer Name <span class=\"text-red-500\">*</span></label>\n                <input \n                  type=\"text\" \n                  id=\"reg-name\" \n                  required \n                  placeholder=\"e.g., Hajime Kashimo\" \n                  class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3.5 py-2 text-sm text-zinc-100 placeholder-zinc-600 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition\"\n                >\n              </div>\n\n              <!-- Colony dropdown -->\n              <div class=\"space-y-1.5\">\n                <label for=\"reg-colony\" class=\"block font-mono text-[11px] uppercase tracking-wider text-zinc-400 font-semibold\">Starting Colony <span class=\"text-red-500\">*</span></label>\n                <select \n                  id=\"reg-colony\" \n                  required \n                  class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3.5 py-2 text-sm text-zinc-200 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition\"\n                >\n                  <option value=\"Tokyo Colony No. 1\">Tokyo Colony No. 1</option>\n                  <option value=\"Tokyo Colony No. 2\">Tokyo Colony No. 2</option>\n                  <option value=\"Sendai Colony\">Sendai Colony</option>\n                  <option value=\"Sakurajima Colony\">Sakurajima Colony</option>\n                  <option value=\"Kyoto Colony\">Kyoto Colony</option>\n                  <option value=\"Iwate Colony\">Iwate Colony</option>\n                </select>\n              </div>\n\n              <!-- Cursed Technique text area -->\n              <div class=\"space-y-1.5\">\n                <label for=\"reg-technique\" class=\"block font-mono text-[11px] uppercase tracking-wider text-zinc-400 font-semibold\">Cursed Technique <span class=\"text-zinc-500\">(Optional)</span></label>\n                <textarea \n                  id=\"reg-technique\" \n                  rows=\"2\"\n                  placeholder=\"Describe intrinsic technique, domain expansion, or cursed tools...\" \n                  class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3.5 py-2 text-sm text-zinc-100 placeholder-zinc-600 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition resize-none scrollbar-thin\"\n                ></textarea>\n              </div>\n\n              <!-- Points field -->\n              <div class=\"grid grid-cols-2 gap-4\">\n                <div class=\"space-y-1.5\">\n                  <label for=\"reg-points\" class=\"block font-mono text-[11px] uppercase tracking-wider text-zinc-400 font-semibold\">Starting Points</label>\n                  <input \n                    type=\"number\" \n                    id=\"reg-points\" \n                    value=\"0\" \n                    min=\"0\" \n                    max=\"1000\" \n                    class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3.5 py-2 text-sm text-zinc-100 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition\"\n                  >\n                </div>\n                <div class=\"space-y-1.5\">\n                  <label for=\"reg-status\" class=\"block font-mono text-[11px] uppercase tracking-wider text-zinc-400 font-semibold\">Initial Status</label>\n                  <select \n                    id=\"reg-status\" \n                    class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3.5 py-2 text-sm text-zinc-200 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition\"\n                  >\n                    <option value=\"Alive\" selected>Alive (Green)</option>\n                    <option value=\"Deceased\">Deceased (Red)</option>\n                  </select>\n                </div>\n              </div>\n\n              <!-- Submit button -->\n              <button \n                type=\"submit\" \n                class=\"w-full mt-2 bg-gradient-to-r from-red-700 to-purple-800 hover:from-red-600 hover:to-purple-700 text-zinc-100 font-display font-bold py-3 px-4 rounded text-xs tracking-widest uppercase transition-all duration-300 hover:shadow-[0_0_15px_rgba(239,68,68,0.3)] border border-red-500/20\"\n              >\n                Enter the Culling Game\n              </button>\n            </form>\n          </div>\n\n          <!-- TAB 2: POINT TRANSFER SIMULATOR -->\n          <div id=\"left-tab-transfer\" class=\"hidden space-y-5\">\n            <div>\n              <h2 class=\"font-display font-bold text-zinc-200 text-sm tracking-widest uppercase mb-1\">Point Transfer Mechanism</h2>\n              <p class=\"text-zinc-500 font-mono text-[11px] uppercase\">Enforce point-exchange rule #10 between active players.</p>\n            </div>\n\n            <form id=\"transfer-form\" onsubmit=\"simulateTransfer(event)\" class=\"space-y-4\">\n              <!-- Sender Selection -->\n              <div class=\"space-y-1.5\">\n                <label for=\"trans-sender\" class=\"block font-mono text-[11px] uppercase tracking-wider text-zinc-400 font-semibold\">Sender <span class=\"text-zinc-500\">(Transfers Out)</span></label>\n                <select \n                  id=\"trans-sender\" \n                  required \n                  class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3.5 py-2 text-sm text-zinc-200 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition\"\n                >\n                  <!-- Populated dynamically -->\n                </select>\n              </div>\n\n              <!-- Receiver Selection -->\n              <div class=\"space-y-1.5\">\n                <label for=\"trans-receiver\" class=\"block font-mono text-[11px] uppercase tracking-wider text-zinc-400 font-semibold\">Receiver <span class=\"text-zinc-500\">(Receives In)</span></label>\n                <select \n                  id=\"trans-receiver\" \n                  required \n                  class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3.5 py-2 text-sm text-zinc-200 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition\"\n                >\n                  <!-- Populated dynamically -->\n                </select>\n              </div>\n\n              <!-- Points to Transfer -->\n              <div class=\"space-y-1.5\">\n                <label for=\"trans-amount\" class=\"block font-mono text-[11px] uppercase tracking-wider text-zinc-400 font-semibold\">Points to Transfer</label>\n                <div class=\"relative\">\n                  <input \n                    type=\"number\" \n                    id=\"trans-amount\" \n                    value=\"1\" \n                    min=\"1\" \n                    class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3.5 py-2 pr-12 text-sm text-zinc-100 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition\"\n                  >\n                  <span class=\"absolute right-3.5 top-2 text-xs font-mono text-zinc-600 font-bold uppercase\">PTS</span>\n                </div>\n              </div>\n\n              <!-- Submit button -->\n              <button \n                type=\"submit\" \n                class=\"w-full mt-2 bg-purple-700 hover:bg-purple-600 text-zinc-100 font-display font-bold py-3 px-4 rounded text-xs tracking-widest uppercase transition-all duration-300 hover:shadow-[0_0_15px_rgba(139,92,246,0.3)] border border-purple-500/20\"\n              >\n                Authorize Point Transfer\n              </button>\n            </form>\n          </div>\n\n        </div>\n\n        <!-- MONOSPACE KOGANE LOGS FEED (FIXED AT THE BOTTOM) -->\n        <div class=\"bg-zinc-950 border-t border-zinc-800 p-4 h-48 flex flex-col shrink-0\">\n          <div class=\"flex items-center justify-between mb-2 shrink-0\">\n            <span class=\"font-mono text-[10px] tracking-wider text-zinc-400 font-bold uppercase flex items-center gap-1.5\">\n              <span class=\"w-1.5 h-1.5 bg-yellow-500 rounded-full animate-pulse\"></span> Kogane Broadcast Feed\n            </span>\n            <button onclick=\"clearLogs()\" class=\"font-mono text-[9px] text-zinc-600 hover:text-zinc-400 uppercase tracking-widest\">Clear</button>\n          </div>\n          <!-- Log List -->\n          <div id=\"logs-container\" class=\"flex-1 overflow-y-auto scrollbar-thin text-[11px] font-mono space-y-1.5 pr-2\">\n            <!-- Log items appended here -->\n          </div>\n        </div>\n\n      </section>\n\n      <!-- RIGHT PANEL: MONITORING GRID & STATS (70% width) -->\n      <section class=\"flex-1 bg-zinc-950 flex flex-col h-full overflow-hidden\">\n        \n        <!-- TOP GAME STATISTICS BAR -->\n        <div class=\"bg-zinc-900/60 border-b border-zinc-800 p-4 shrink-0\">\n          <div class=\"grid grid-cols-2 lg:grid-cols-4 gap-4 max-w-7xl mx-auto\">\n            \n            <!-- Metric 1: Registered -->\n            <div class=\"bg-zinc-900 border border-zinc-800 p-3.5 rounded-md flex items-center gap-4\">\n              <div class=\"p-2.5 bg-purple-950/40 border border-purple-900/40 text-purple-400 rounded\">\n                <!-- User Plus Icon SVG -->\n                <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z\" /></svg>\n              </div>\n              <div>\n                <span class=\"text-zinc-500 font-mono text-[10px] uppercase block tracking-wider\">Total Sorcerers</span>\n                <span id=\"stat-total-players\" class=\"font-display font-bold text-xl text-zinc-100\">0</span>\n              </div>\n            </div>\n\n            <!-- Metric 2: Points -->\n            <div class=\"bg-zinc-900 border border-zinc-800 p-3.5 rounded-md flex items-center gap-4\">\n              <div class=\"p-2.5 bg-yellow-950/40 border border-yellow-900/40 text-yellow-500 rounded\">\n                <!-- Coins/Star Icon SVG -->\n                <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z\" /></svg>\n              </div>\n              <div>\n                <span class=\"text-zinc-500 font-mono text-[10px] uppercase block tracking-wider\">Total Game Points</span>\n                <span id=\"stat-total-points\" class=\"font-display font-bold text-xl text-yellow-500\">0</span>\n              </div>\n            </div>\n\n            <!-- Metric 3: Mortalities -->\n            <div class=\"bg-zinc-900 border border-zinc-800 p-3.5 rounded-md flex items-center gap-4\">\n              <div class=\"p-2.5 bg-red-950/40 border border-red-900/40 text-red-500 rounded\">\n                <!-- Skull Icon SVG -->\n                <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\" /></svg>\n              </div>\n              <div>\n                <span class=\"text-zinc-500 font-mono text-[10px] uppercase block tracking-wider\">Deceased Rate</span>\n                <span id=\"stat-mortality-rate\" class=\"font-display font-bold text-xl text-red-400\">0%</span>\n              </div>\n            </div>\n\n            <!-- Metric 4: Rules Added -->\n            <div class=\"bg-zinc-900 border border-zinc-800 p-3.5 rounded-md flex items-center gap-4\">\n              <div class=\"p-2.5 bg-blue-950/40 border border-blue-900/40 text-blue-400 rounded\">\n                <!-- Scroll Icon SVG -->\n                <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z\" /></svg>\n              </div>\n              <div class=\"flex-1 flex justify-between items-center\">\n                <div>\n                  <span class=\"text-zinc-500 font-mono text-[10px] uppercase block tracking-wider\">Culling Rules</span>\n                  <span class=\"font-display font-bold text-xl text-zinc-100\">19 clauses</span>\n                </div>\n                <button onclick=\"openRulesModal()\" class=\"text-[10px] bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-mono uppercase px-2 py-1 rounded border border-zinc-700 transition\">View</button>\n              </div>\n            </div>\n\n          </div>\n        </div>"
        replacement_content: "      <!-- LEFT PANEL: REGISTRATION ZONE & LOGS (320px width) -->\n      <section class=\"w-full md:w-[320px] bg-zinc-900/50 border-r border-zinc-800 flex flex-col h-full overflow-hidden shrink-0\">\n        \n        <!-- Tab Selectors for Left Side -->\n        <div class=\"flex border-b border-zinc-800 font-mono text-xs uppercase shrink-0\">\n          <button id=\"tab-register-btn\" onclick=\"switchLeftTab(\'register\')\" class=\"flex-1 py-3 text-center border-b-2 border-purple-500 text-purple-400 font-bold bg-zinc-900/50 transition\">\n            Participation\n          </button>\n          <button id=\"tab-transfer-btn\" onclick=\"switchLeftTab(\'transfer\')\" class=\"flex-1 py-3 text-center border-b-2 border-transparent text-zinc-500 hover:text-zinc-300 transition\">\n            Point Transfer\n          </button>\n        </div>\n\n        <!-- Scrollable content area -->\n        <div class=\"flex-1 overflow-y-auto p-5 scrollbar-thin space-y-6\">\n\n          <!-- TAB 1: REGISTRATION FORM -->\n          <div id=\"left-tab-register\" class=\"space-y-5\">\n            <div>\n              <h2 class=\"text-[11px] uppercase tracking-[0.2em] text-zinc-500 mb-4 flex items-center gap-2\">\n                <span class=\"w-4 h-[1px] bg-zinc-700\"></span> Player Registration\n              </h2>\n            </div>\n\n            <form id=\"registration-form\" onsubmit=\"registerPlayer(event)\" class=\"space-y-4\">\n              <!-- Name field -->\n              <div class=\"space-y-1.5\">\n                <label for=\"reg-name\" class=\"text-[9px] uppercase tracking-wider text-zinc-500 font-bold block mb-1\">Sorcerer Name <span class=\"text-red-500\">*</span></label>\n                <input \n                  type=\"text\" \n                  id=\"reg-name\" \n                  required \n                  placeholder=\"e.g., Hajime Kashimo\" \n                  class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3 py-2 text-sm text-zinc-100 focus:outline-none focus:ring-1 focus:ring-purple-500 focus:border-purple-500 placeholder:text-zinc-700 transition\"\n                >\n              </div>\n\n              <!-- Colony dropdown -->\n              <div class=\"space-y-1.5\">\n                <label for=\"reg-colony\" class=\"text-[9px] uppercase tracking-wider text-zinc-500 font-bold block mb-1\">Starting Colony <span class=\"text-red-500\">*</span></label>\n                <select \n                  id=\"reg-colony\" \n                  required \n                  class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3 py-2 text-sm text-zinc-300 focus:outline-none focus:ring-1 focus:ring-purple-500 transition\"\n                >\n                  <option value=\"Tokyo Colony No. 1\">Tokyo Colony No. 1</option>\n                  <option value=\"Tokyo Colony No. 2\">Tokyo Colony No. 2</option>\n                  <option value=\"Sendai Colony\">Sendai Colony</option>\n                  <option value=\"Sakurajima Colony\">Sakurajima Colony</option>\n                  <option value=\"Kyoto Colony\">Kyoto Colony</option>\n                  <option value=\"Iwate Colony\">Iwate Colony</option>\n                </select>\n              </div>\n\n              <!-- Cursed Technique text area -->\n              <div class=\"space-y-1.5\">\n                <label for=\"reg-technique\" class=\"text-[9px] uppercase tracking-wider text-zinc-500 font-bold block mb-1\">Cursed Technique Specification <span class=\"text-zinc-600\">(Optional)</span></label>\n                <textarea \n                  id=\"reg-technique\" \n                  rows=\"2\"\n                  placeholder=\"Describe intrinsic technique, domain expansion, or cursed tools...\" \n                  class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3 py-2 text-sm text-zinc-100 focus:outline-none focus:ring-1 focus:ring-purple-500 focus:border-purple-500 placeholder:text-zinc-700 resize-none scrollbar-thin\"\n                ></textarea>\n              </div>\n\n              <!-- Points field -->\n              <div class=\"grid grid-cols-2 gap-4\">\n                <div class=\"space-y-1.5\">\n                  <label for=\"reg-points\" class=\"text-[9px] uppercase tracking-wider text-zinc-500 font-bold block mb-1\">Starting Points</label>\n                  <input \n                    type=\"number\" \n                    id=\"reg-points\" \n                    value=\"0\" \n                    min=\"0\" \n                    max=\"1000\" \n                    class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3 py-2 text-sm text-zinc-100 focus:outline-none focus:ring-1 focus:ring-purple-500 transition\"\n                  >\n                </div>\n                <div class=\"space-y-1.5\">\n                  <label for=\"reg-status\" class=\"text-[9px] uppercase tracking-wider text-zinc-500 font-bold block mb-1\">Initial Status</label>\n                  <select \n                    id=\"reg-status\" \n                    class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3 py-2 text-sm text-zinc-300 focus:outline-none focus:ring-1 focus:ring-purple-500 transition\"\n                  >\n                    <option value=\"Alive\" selected>Alive (Green)</option>\n                    <option value=\"Deceased\">Deceased (Red)</option>\n                  </select>\n                </div>\n              </div>\n\n              <!-- Submit button -->\n              <button \n                type=\"submit\" \n                class=\"w-full bg-red-600 hover:bg-red-700 text-white font-bold py-4 rounded text-xs uppercase tracking-[0.2em] shadow-[0_0_20px_rgba(220,38,38,0.2)] flex items-center justify-center gap-2 transition-all cursor-pointer\"\n              >\n                Enter the Culling Game\n              </button>\n              <p class=\"text-[8px] text-zinc-600 text-center mt-3 uppercase tracking-tighter\">Warning: Binding vow active upon submission.</p>\n            </form>\n          </div>\n\n          <!-- TAB 2: POINT TRANSFER SIMULATOR -->\n          <div id=\"left-tab-transfer\" class=\"hidden space-y-5\">\n            <div>\n              <h2 class=\"text-[11px] uppercase tracking-[0.2em] text-zinc-500 mb-4 flex items-center gap-2\">\n                <span class=\"w-4 h-[1px] bg-zinc-700\"></span> Point Transfer\n              </h2>\n            </div>\n\n            <form id=\"transfer-form\" onsubmit=\"simulateTransfer(event)\" class=\"space-y-4\">\n              <!-- Sender Selection -->\n              <div class=\"space-y-1.5\">\n                <label for=\"trans-sender\" class=\"text-[9px] uppercase tracking-wider text-zinc-500 font-bold block mb-1\">Sender <span class=\"text-zinc-600\">(Transfers Out)</span></label>\n                <select \n                  id=\"trans-sender\" \n                  required \n                  class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3 py-2 text-sm text-zinc-300 focus:outline-none focus:ring-1 focus:ring-purple-500 transition\"\n                >\n                  <!-- Populated dynamically -->\n                </select>\n              </div>\n\n              <!-- Receiver Selection -->\n              <div class=\"space-y-1.5\">\n                <label for=\"trans-receiver\" class=\"text-[9px] uppercase tracking-wider text-zinc-500 font-bold block mb-1\">Receiver <span class=\"text-zinc-600\">(Receives In)</span></label>\n                <select \n                  id=\"trans-receiver\" \n                  required \n                  class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3 py-2 text-sm text-zinc-300 focus:outline-none focus:ring-1 focus:ring-purple-500 transition\"\n                >\n                  <!-- Populated dynamically -->\n                </select>\n              </div>\n\n              <!-- Points to Transfer -->\n              <div class=\"space-y-1.5\">\n                <label for=\"trans-amount\" class=\"text-[9px] uppercase tracking-wider text-zinc-500 font-bold block mb-1\">Points to Transfer</label>\n                <div class=\"relative\">\n                  <input \n                    type=\"number\" \n                    id=\"trans-amount\" \n                    value=\"1\" \n                    min=\"1\" \n                    class=\"w-full bg-zinc-950 border border-zinc-800 rounded px-3 py-2 pr-12 text-sm text-zinc-100 focus:outline-none focus:ring-1 focus:ring-purple-500 transition\"\n                  >\n                  <span class=\"absolute right-3.5 top-2.5 text-xs font-mono text-zinc-600 font-bold uppercase\">PTS</span>\n                </div>\n              </div>\n\n              <!-- Submit button -->\n              <button \n                type=\"submit\" \n                class=\"w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-4 rounded text-xs uppercase tracking-[0.2em] shadow-[0_0_20px_rgba(147,51,234,0.2)] flex items-center justify-center gap-2 transition-all cursor-pointer\"\n              >\n                Authorize Transfer\n              </button>\n            </form>\n          </div>\n\n        </div>\n\n        <!-- MONOSPACE KOGANE LOGS FEED (FIXED AT THE BOTTOM) -->\n        <div class=\"bg-zinc-950 border-t border-zinc-800 p-4 h-48 flex flex-col shrink-0\">\n          <div class=\"flex items-center justify-between mb-2 shrink-0\">\n            <span class=\"font-mono text-[10px] tracking-wider text-zinc-400 font-bold uppercase flex items-center gap-1.5\">\n              <span class=\"w-1.5 h-1.5 bg-yellow-500 rounded-full animate-pulse\"></span> Kogane Broadcast Feed\n            </span>\n            <button onclick=\"clearLogs()\" class=\"font-mono text-[9px] text-zinc-600 hover:text-zinc-400 uppercase tracking-widest cursor-pointer\">Clear</button>\n          </div>\n          <!-- Log List -->\n          <div id=\"logs-container\" class=\"flex-1 overflow-y-auto scrollbar-thin text-[11px] font-mono space-y-1.5 pr-2\">\n            <!-- Log items appended here -->\n          </div>\n        </div>\n\n      </section>\n\n      <!-- RIGHT PANEL: MONITORING GRID & STATS (70% width) -->\n      <section class=\"flex-1 bg-zinc-950 flex flex-col h-full overflow-hidden\">\n        \n        <!-- MONITORING HEADER (STATS BAR) -->\n        <div class=\"h-20 flex items-center px-8 border-b border-zinc-800 bg-zinc-950/80 backdrop-blur-sm shrink-0\">\n          <div class=\"grid grid-cols-2 md:grid-cols-4 gap-x-12 gap-y-2 w-full max-w-7xl mx-auto font-mono\">\n            <div class=\"flex flex-col\">\n              <span class=\"text-[10px] uppercase text-zinc-500 tracking-widest\">Active Sorcerers</span>\n              <span id=\"stat-total-players\" class=\"text-2xl md:text-3xl text-zinc-100 font-black\">0</span>\n            </div>\n            <div class=\"flex flex-col border-l border-zinc-900 md:border-zinc-800 pl-6 md:pl-12\">\n              <span class=\"text-[10px] uppercase text-zinc-500 tracking-widest\">Points Distributed</span>\n              <span id=\"stat-total-points\" class=\"text-2xl md:text-3xl text-purple-400 font-black\">0</span>\n            </div>\n            <div class=\"flex flex-col border-l border-zinc-900 md:border-zinc-800 pl-6 md:pl-12\">\n              <span class=\"text-[10px] uppercase text-zinc-500 tracking-widest\">Deceased Rate</span>\n              <span id=\"stat-mortality-rate\" class=\"text-2xl md:text-3xl text-red-500 font-black\">0%</span>\n            </div>\n            <div class=\"flex flex-col border-l border-zinc-900 md:border-zinc-800 pl-6 md:pl-12 justify-center\">\n              <span class=\"text-[10px] uppercase text-zinc-500 tracking-widest block\">Culling Rules</span>\n              <div class=\"flex items-center gap-2\">\n                <span class=\"text-xl md:text-2xl text-zinc-100 font-black\">19 Rules</span>\n                <button onclick=\"openRulesModal()\" class=\"text-[8px] bg-zinc-900 hover:bg-zinc-800 text-zinc-400 font-mono uppercase px-1.5 py-0.5 rounded border border-zinc-800 transition cursor-pointer\">View</button>\n              </div>\n            </div>\n          </div>\n        </div>"
      }
      num_matches: 1
    }
  }
}
