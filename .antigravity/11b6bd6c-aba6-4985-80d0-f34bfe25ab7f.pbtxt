          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // 3. Application Lifecycle Setup"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // -------------------------------------------------------------"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      window.onload = function() {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Load data from localStorage or seed database if empty"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const storedPlayers = localStorage.getItem(\'culling_games_sorcerers\');"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (storedPlayers) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          try {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            players = JSON.parse(storedPlayers);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          } catch(e) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            players = [...initialPlayers];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        } else {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          players = [...initialPlayers];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          localStorage.setItem(\'culling_games_sorcerers\', JSON.stringify(players));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Initialize display components"
