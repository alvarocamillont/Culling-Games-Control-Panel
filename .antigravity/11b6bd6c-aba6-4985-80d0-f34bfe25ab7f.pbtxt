          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      function startClock() {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const systemClockEl = document.getElementById(\'system-clock\');"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        setInterval(() => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          const now = new Date();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          const formatStr = now.toISOString().replace(\'T\', \' \').substring(0, 19) + \' UTC\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          systemClockEl.innerText = formatStr;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        }, 1000);"
