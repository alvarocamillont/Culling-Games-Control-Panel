          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              <h3 class=\"font-display font-bold text-zinc-100 uppercase tracking-widest text-sm\">Culling Game Declarative Rules</h3>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              <p class=\"text-zinc-500 font-mono text-[10px] uppercase\">The binding vow governing Kenjaku\'s game board</p>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
